{
  "expo": {
    "name": "OOF",
    "slug": "oof",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "oof",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#05050F"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.oofapp.meets",
      "config": {
        "googleMapsApiKey": "AIzaSyBN2H0Lh-y9vuNXQ4t4QFOnhMSAnLDznXY"
      },
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "OOF uses your location to show nearby car meets and help you post meets in your area.",
        "NSPhotoLibraryUsageDescription": "OOF uses your photo library so you can add a profile photo and car photo to your card.",
        "NSPhotoLibraryAddUsageDescription": "OOF saves photos to your library when sharing your card.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#05050F"
      },
      "package": "com.oofapp.meets",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "OOF uses your camera to scan QR codes and connect with other car enthusiasts."
        }
      ],
      "expo-font"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "cd0d7d26-c122-4576-bc6c-b92a1e20cb96"
      }
    }
  }
}
