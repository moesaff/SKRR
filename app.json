{
  "expo": {
    "name": "SKRR",
    "slug": "skrr",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "skrr",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#05050F"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.skrr.app",
      "config": {
        "googleMapsApiKey": "AIzaSyBN2H0Lh-y9vuNXQ4t4QFOnhMSAnLDznXY"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#05050F"
      },
      "package": "com.skrr.app"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "SKRR uses your camera to scan QR codes and connect with other car enthusiasts."
        }
      ]
    ]
  }
}
